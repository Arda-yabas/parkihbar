rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar kendi dokümanlarını okuyup yazabilir
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Bildirimler — kullanıcı kendi bildirimlerini okuyabilir, Cloud Function yazar
    match /notifications/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // sadece Cloud Function yazar
    }

    // Reports — herkes okuyabilir, auth olan yazabilir
    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // sadece Cloud Function günceller

      // Yorumlar — herkes okuyabilir, auth olan yazar, yazar veya ihbar sahibi silebilir
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/reports/$(reportId)).data.userId == request.auth.uid
        );
        allow update: if false;
      }
    }

    // Settings — moderatör FCM token kaydı için auth olan yazabilir
    match /settings/{docId} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // Donations — herkes okuyabilir, auth olan tıklama sayacı artırabilir
    match /donations/{causeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
